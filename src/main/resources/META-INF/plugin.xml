<idea-plugin>
    <id>com.github.mohamedshemees.kmpresourcesunfold</id>
    <name>Kmp Resources Unfold</name>
    <vendor email="mohamed.shemees.dev@gmail.com">Mohamed Shemees</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.kotlin</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>org.jetbrains.android</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true" />
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                factoryClass="com.github.mohamedshemees.kmpresourcesunfold.toolWindow.MyToolWindowFactory"
                id="Kmp Resources Unfold"
                anchor="left"
                icon="/icons/logo.png" />

        <fileEditorProvider implementation="com.github.mohamedshemees.kmpresourcesunfold.toolWindow.VectorPreviewProvider"
                            order="first, before text-editor"/>
    </extensions>
</idea-plugin>
<idea-plugin>
    <id>com.github.mohamedshemees.kmpresourcesunfold</id>
    <name>Kmp Resources Unfold</name>
    <vendor email="mohamed.shemees.dev@gmail.com">Mohamed Shemees</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>org.jetbrains.android</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true" />
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                factoryClass="com.github.mohamedshemees.kmpresourcesunfold.toolWindow.MyToolWindowFactory"
                id="Kmp Resources Unfold"
                anchor="left"
                icon="/icons/logo.png" />

        <fileEditorProvider implementation="com.github.mohamedshemees.kmpresourcesunfold.toolWindow.VectorPreviewProvider"
                            order="first, before text-editor"/>

        <codeInsight.lineMarkerProvider language="XML"
                                        implementationClass="com.github.mohamedshemees.kmpresourcesunfold.navigation.ResourceLocalizationLineMarkerProvider"/>
        <psi.referenceContributor language="XML"
                                  implementation="com.github.mohamedshemees.kmpresourcesunfold.navigation.ResourceKeyReferenceContributor"/>
        <localInspection language="XML"
                         displayName="Missing resource translation"
                         groupName="KMP resources"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.github.mohamedshemees.kmpresourcesunfold.lint.MissingTranslationInspection"/>
    </extensions>
</idea-plugin>